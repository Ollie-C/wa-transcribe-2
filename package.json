{
  "name": "wa-transcribe-2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite dev",
    "dev:local": "bash ./scripts/dev-local.sh",
    "build": "svelte-kit sync && vite build",
    "build:hosted": "VITE_USE_RELATIVE_API=true svelte-kit sync && vite build",
    "serve:hosted": "bash ./scripts/run-hosted.sh",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "diff": "^7.0.0",
    "fuse.js": "^7.1.0",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0",
    "svelte": "^5.39.3",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^4.1.1"
  }
}
